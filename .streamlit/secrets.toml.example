# Copy this file to .streamlit/secrets.toml and fill in your Supabase URL.
# NEVER commit secrets.toml — it is already in .gitignore.
#
# Where to find this URL:
#   Supabase Dashboard → your project → Project Settings → Database
#   → Connection string → URI  (use the "Session mode" / port 5432 URL)
#
# It looks like:
#   postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

DATABASE_URL = "postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
